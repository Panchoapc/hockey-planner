// Schema Dia 2 — scheduler FEHOCH con recintos y localia.
// Postgres (Supabase). DATABASE_URL (pooled 6543) + DIRECT_URL (5432).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Genero {
  VARONES
  DAMAS
}

enum Formato {
  ADULTO
  SUB14
  SUB12
}

enum Rueda {
  UNICA
  DOBLE
}

model Club {
  id      String   @id @default(cuid())
  nombre  String   @unique
  equipos Equipo[]
}

// Un recinto (sede). Recurso escaso: 1 cancha, capacidad = slots del finde.
// admiteVarones se DERIVA en el seed (true sii un equipo masculino es local).
model Recinto {
  id            String    @id @default(cuid())
  nombre        String    @unique
  ciudad        String
  admiteVarones Boolean
  equiposLocal  Equipo[]
  partidos      Partido[]
}

model Categoria {
  id        String    @id @default(cuid())
  slug      String    @unique
  nombre    String
  genero    Genero
  formato   Formato
  rueda     Rueda
  bloqueMin Int
  equipos   Equipo[]
  partidos  Partido[]
}

model Equipo {
  id             String    @id @default(cuid())
  nombre         String
  categoria      Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  categoriaId    String
  club           Club?     @relation(fields: [clubId], references: [id])
  clubId         String?
  recintoLocal   Recinto   @relation(fields: [recintoLocalId], references: [id])
  recintoLocalId String
  partidosLocal  Partido[] @relation("local")
  partidosVisita Partido[] @relation("visita")

  @@unique([categoriaId, nombre])
}

model Partido {
  id          String    @id @default(cuid())
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  categoriaId String
  local       Equipo    @relation("local", fields: [localId], references: [id])
  localId     String
  visita      Equipo    @relation("visita", fields: [visitaId], references: [id])
  visitaId    String
  jornada     Int

  // Resultado del scheduler. Null = sin asignar (saturacion).
  recinto   Recinto? @relation(fields: [recintoId], references: [id])
  recintoId String?
  fecha     String?
  hora      String?
  arbitros  String[] @default([])

  @@index([categoriaId])
}
